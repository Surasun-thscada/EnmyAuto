  "components": {
    "schemas": {
      "ChangePasswordRequest": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string",
            "nullable": true
          },
          "newPassword": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateCampaignRequest": {
        "required": [
          "scheduledTime",
          "storyboardId",
          "tikTokAccountId"
        ],
        "type": "object",
        "properties": {
          "storyboardId": {
            "type": "string",
            "format": "uuid"
          },
          "tikTokAccountId": {
            "type": "string",
            "format": "uuid"
          },
          "scheduledTime": {
            "type": "string",
            "format": "date-time"
          },
          "customCaption": {
            "type": "string",
            "nullable": true
          },
          "privacyLevel": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GenerateStoryboardRequest": {
        "required": [
          "category",
          "productName"
        ],
        "type": "object",
        "properties": {
          "productName": {
            "maxLength": 120,
            "minLength": 1,
            "type": "string"
          },
          "category": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RefreshTokenRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateProfileRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateSettingsRequest": {
        "type": "object",
        "properties": {
          "geminiApiKey": {
            "type": "string",
            "nullable": true
          },
          "geminiModel": {
            "type": "string",
            "nullable": true
          },
          "temperature": {
            "type": "number",
            "format": "float"
          },
          "maxOutputTokens": {
            "type": "integer",
            "format": "int32"
          },
          "contentLanguage": {
            "type": "string",
            "nullable": true
          },
          "contentTone": {
            "type": "string",
            "nullable": true
          },
          "defaultCategory": {
            "type": "string",
            "nullable": true
          },
          "defaultSceneCount": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
